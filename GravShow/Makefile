####### Compile

main.o: main.cpp mainwindow.h \
		datamodel.h \
		shmdatacollector.h \
		datarecorder.h \
		chartwidget.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

mainwindow.o: mainwindow.cpp mainwindow.h \
		datamodel.h \
		shmdatacollector.h \
		datarecorder.h \
		chartwidget.h \
		ui_mainwindow.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mainwindow.o mainwindow.cpp

datamodel.o: datamodel.cpp datamodel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o datamodel.o datamodel.cpp

shmdatacollector.o: shmdatacollector.cpp shmdatacollector.h \
		datamodel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o shmdatacollector.o shmdatacollector.cpp

datarecorder.o: datarecorder.cpp datarecorder.h \
		datamodel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o datarecorder.o datarecorder.cpp

chartwidget.o: chartwidget.cpp chartwidget.h \
		datamodel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o chartwidget.o chartwidget.cpp

moc_mainwindow.o: moc_mainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mainwindow.o moc_mainwindow.cpp

moc_datamodel.o: moc_datamodel.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_datamodel.o moc_datamodel.cpp

moc_shmdatacollector.o: moc_shmdatacollector.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_shmdatacollector.o moc_shmdatacollector.cpp

moc_datarecorder.o: moc_datarecorder.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_datarecorder.o moc_datarecorder.cpp

moc_chartwidget.o: moc_chartwidget.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_chartwidget.o moc_chartwidget.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/GravShow/bin || mkdir -p $(INSTALL_ROOT)/opt/GravShow/bin
	-$(QINSTALL_PROGRAM) bin/$(QMAKE_TARGET) $(INSTALL_ROOT)/opt/GravShow/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/GravShow/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/GravShow/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/GravShow/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

